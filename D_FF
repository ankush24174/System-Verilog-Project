class environment;
  generator gen; // Generator instance
  driver drv; // Driver instance
  monitor mon; // Monitor instance
  scoreboard sco; // Scoreboard instance
  event next; // Synchronization event between the generator and scoreboard

  mailbox #(transaction) gdmbx; // Mailbox for Generator-Driver communication
  mailbox #(transaction) msmbx; // Mailbox for Monitor-Scoreboard communication
  mailbox #(transaction) mbxref; // Mailbox for Generator-Scoreboard reference data

  virtual dff_if vif; // Virtual interface handle for the DUT

  function new(virtual dff_if vif);
    gdmbx = new(); // Instantiate the generator-driver mailbox
    mbxref = new(); // Instantiate the generator-scoreboard reference mailbox
    gen = new(gdmbx, mbxref); // Construct the generator
    drv = new(gdmbx); // Construct the driver
    msmbx = new(); // Instantiate the monitor-scoreboard mailbox
    mon = new(msmbx); // Construct the monitor
    sco = new(msmbx, mbxref); // Construct the scoreboard
    this.vif = vif; // Store the virtual interface handle
    drv.vif = this.vif; // Connect the virtual interface to the driver
    mon.vif = this.vif; // Connect the virtual interface to the monitor
    gen.sconext = next; // Establish synchronization event for generator
    sco.sconext = next; // Establish synchronization event for scoreboard
  endfunction

  task pre_test();
    drv.reset(); // Execute the pre-test reset sequence
  endtask

  task test();
    fork // Initiate parallel execution of the components
      gen.run(); // Start the stimulus generator
      drv.run(); // Start the driver
      mon.run(); // Start the monitor
      sco.run(); // Start the scoreboard
    join_any // Wait for any of the tasks to complete (specifically, 'gen.run' will signal the end)
  endtask

  task post_test();
    wait(gen.done.triggered); // Wait for the generator's 'done' event to be triggered
    $finish(); // Terminate the simulation
  endtask

  task run();
    pre_test(); // Execute pre-test setup
    test(); // Execute the main test scenario
    post_test(); // Execute post-test cleanup and termination
  endtask
endclass

