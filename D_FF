class generator;
  transaction tr;  // Handle for a transaction object
  mailbox #(transaction) mbx;      // Mailbox for sending transactions to the driver
  mailbox #(transaction) mbxref;   // Mailbox for sending reference transactions (golden data) to the scoreboard
  event sconext; // Event to synchronize with the scoreboard's completion of a check
  event done;    // Event to signal the completion of stimulus generation
  int count;     // Total number of stimuli to be generated

  function new(mailbox #(transaction) mbx, mailbox #(transaction) mbxref);
    this.mbx = mbx;  // Initialize the driver mailbox handle
    this.mbxref = mbxref; // Initialize the scoreboard reference mailbox handle
    tr = new(); // Instantiate a new transaction object
  endfunction

// The purpose of the run method is to randomize data and transmit it to the driver and scoreboard.
  task run();
    repeat(count) begin
      assert(tr.randomize) else $error("\[GEN\] : RANDOMIZATION FAILED");
      mbx.put(tr.copy); // Place a copy of the randomized transaction into the driver mailbox
      mbxref.put(tr.copy); // Place a copy of the transaction into the scoreboard reference mailbox
      tr.display("GEN"); // Log the generated transaction
      @(sconext); // Wait for the scoreboard to complete the current comparison
    end
    ->done; // Trigger the "done" event upon completion of all stimuli
  endtask

endclass

