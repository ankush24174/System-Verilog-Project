class driver;
  transaction tr; // Handle for the received transaction object
  mailbox #(transaction) mbx; // Mailbox for receiving transactions from the generator
  virtual dff_if vif; // Virtual interface handle connected to the DUT

  function new(mailbox #(transaction) mbx);
    this.mbx = mbx; // Initialize the mailbox handle
  endfunction

  task reset();
    vif.rst <= 1'b1; // Assert the reset signal
    repeat(5) @(posedge vif.clk); // Wait for 5 clock cycles
    vif.rst <= 1'b0; // Deassert the reset signal
    @(posedge vif.clk); // Wait for an additional clock cycle
    $display("\[DRV\] : RESET DONE"); // Log reset completion
  endtask

  task run();
    forever begin
      mbx.get(tr); // Retrieve a transaction from the generator
      vif.din <= tr.din; // Drive the DUT input based on the transaction data
      @(posedge vif.clk); // Wait for the rising edge of the clock (data setup)
      tr.display("DRV"); // Log the transaction being driven
      vif.din <= 1'b0; // Deassert the data input (or set to a default value)
      @(posedge vif.clk); // Wait for the next rising edge of the clock
    end
  endtask

endclass

