class transaction;

  rand bit din;    // Random input data bit 'din'
  bit dout;        // Output data bit 'dout'

  function transaction copy();
    copy = new();   // Allocate memory for a new transaction object
    copy.din = this.din;  // Copy the input value from the current object
    copy.dout = this.dout;  // Copy the output value from the current object
  endfunction

  function void display(input string tag);
    $display("\[%0s\] : DIN : %0b DOUT : %0b", tag, din, dout); // Display transaction details
  endfunction

endclass

