class monitor;
  transaction tr; // Handle for the captured transaction object
  mailbox #(transaction) mbx; // Mailbox for sending captured data to the scoreboard
  virtual dff_if vif; // Virtual interface handle connected to the DUT

  function new(mailbox #(transaction) mbx);
    this.mbx = mbx; // Initialize the scoreboard mailbox handle
  endfunction

  task run();
    tr = new(); // Instantiate a new transaction object
    forever begin
      repeat(2) @(posedge vif.clk); // Wait for two rising clock edges (to capture output)
      tr.dout = vif.dout; // Sample the DUT output
      mbx.put(tr); // Transmit the captured transaction to the scoreboard
      tr.display("MON"); // Log the monitored transaction
    end
  endtask

endclass

