class scoreboard;
  transaction tr; // Transaction handle for data from the monitor (actual result)
  transaction trref; // Transaction handle for reference data from the generator (expected result)
  mailbox #(transaction) mbx; // Mailbox for receiving transactions from the monitor
  mailbox #(transaction) mbxref; // Mailbox for receiving reference data from the generator
  event sconext; // Event to signal completion of the current comparison

  function new(mailbox #(transaction) mbx, mailbox #(transaction) mbxref);
    this.mbx = mbx; // Initialize the monitor mailbox handle
    this.mbxref = mbxref; // Initialize the reference mailbox handle
  endfunction

  task run();
    forever begin
      mbx.get(tr); // Retrieve the actual result transaction from the monitor
      mbxref.get(trref); // Retrieve the reference transaction from the generator
      tr.display("SCO"); // Log the actual result
      trref.display("REF"); // Log the expected result
      if (tr.dout == trref.din)
        $display("\[SCO\] : DATA MATCHED"); // Comparison successful
      else
        $display("\[SCO\] : DATA MISMATCHED"); // Comparison failed
      $display("-------------------------------------------------");
      ->sconext; // Signal the generator that the comparison is complete
    end
  endtask

endclass

